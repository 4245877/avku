---
// src/components/pages/HomePage.astro
import Base from "../../layouts/Base.astro";
import "../../styles/pages/home.css";
import fs from "node:fs";
import reportsData from "../../data/reports.json";
import { SITE_URL, localePath, useTranslations, type Lang } from "../../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props as Props;
const t = useTranslations(lang);
const en = lang === "en";
const pick = (uk: string, en2: string) => (en ? en2 : uk);

const numberLocale = en ? "en-US" : "uk-UA";
const formatCounter = (n: number) => {
  const num = Number(n);
  if (!Number.isFinite(num) || num <= 0) return "-";
  return new Intl.NumberFormat(numberLocale).format(num);
};

// Внутрішні маршрути — з урахуванням локалі; ассети — лише з BASE_URL.
const link = (p: string) => localePath(p, lang);

const base = import.meta.env.BASE_URL ?? "/";
const asset = (p: string) => {
  if (!p) return base;
  if (/^https?:\/\//i.test(p)) return p;
  const clean = String(p).replace(/^\//, "");
  const baseFixed = base.endsWith("/") ? base : `${base}/`;
  return encodeURI(`${baseFixed}${clean}`);
};

// 1–3 актуальні потреби (текст — у словнику)
const urgentNeeds = [
  { titleKey: "urgent_need_1_title", descKey: "urgent_need_1_desc", ctaKey: "urgent_need_1_cta", href: "/donate" },
  { titleKey: "urgent_need_2_title", descKey: "urgent_need_2_desc", ctaKey: "urgent_need_2_cta", href: "/donate" },
];

// Напрями діяльності
const activities = [
  { titleKey: "activity_zsu", descKey: "activity_zsu_desc" },
  { titleKey: "activity_humanitarian", descKey: "activity_humanitarian_desc" },
  { titleKey: "activity_manufacturing", descKey: "activity_manufacturing_desc" },
  { titleKey: "activity_veterans", descKey: "activity_veterans_desc" },
];

// Показники
const counters = [
  { target: 0, labelKey: "funds_raised" },
  { target: 11, labelKey: "cars_purchased" },
  { target: 42, labelKey: "drones_delivered" },
  { target: 3120, labelKey: "nets_made" },
];

const reports = Array.isArray(reportsData)
  ? reportsData
  : (reportsData?.reports ?? []);

const formatDate = (iso) => {
  if (!iso) return "";
  const d = new Date(String(iso));
  if (Number.isNaN(d.getTime())) return String(iso);
  return new Intl.DateTimeFormat(en ? "en" : "uk-UA", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(d);
};

const lastThree = reports.slice(-3).reverse();

const photoReports = lastThree.map((r) => {
  const titleUk = r?.titleFallback || r?.titleKey || "Фотозвіт";
  const dateLabel = formatDate(r?.dateISO);
  const text = en
    ? (dateLabel ? `${dateLabel} — Photo report` : "Photo report")
    : (dateLabel ? `${dateLabel} — ${titleUk}` : titleUk);

  const cover = Array.isArray(r?.media) && r.media.length ? r.media[0] : null;
  const img = cover?.src ? `/${String(cover.src).replace(/^\//, "")}` : "/logo.png";
  const alt = cover?.alt || titleUk;
  const href = r?.id ? `${link("/reports")}#${encodeURIComponent(String(r.id))}` : link("/reports");

  return { img, alt, text, href };
});

// Відгуки
const testimonials = [
  {
    quote: "Дякуємо за FPV-дрони — вони вже в підрозділах і допомагають виконувати бойові задачі щодня.",
    quoteEn: "Thank you for the FPV drones. They are already with the units and help them carry out combat tasks every day.",
    cite: "– Військові підрозділи (подяка)",
    citeEn: "- Military units (gratitude message)",
  },
  {
    quote: "Отримана допомога (сітки, одяг, гігієна) підсилює наші позиції та покращує умови служби. Дякуємо!",
    quoteEn: "The received aid - nets, clothing, and hygiene supplies - strengthens our positions and improves service conditions. Thank you!",
    cite: "– Захисники на напрямку",
    citeEn: "- Defenders on the front line",
  },
];

// Логотипи партнерів з public/images/partners
const partnersPublicDir = new URL("../../../public/images/partners/", import.meta.url);
let partnerFiles = [];
try {
  partnerFiles = fs
    .readdirSync(partnersPublicDir, { withFileTypes: true })
    .filter((d) => d.isFile())
    .map((d) => d.name)
    .filter((name) => /\.(png|jpg|jpeg|webp|svg)$/i.test(name));
} catch {
  partnerFiles = [];
}

const normalizeBaseName = (filename) =>
  String(filename || "").trim().toLowerCase().replace(/\.[a-z0-9]+$/i, "");

const partnerFilesLower = new Map(partnerFiles.map((f) => [f.toLowerCase(), f]));

const resolveLogoFile = (hint) => {
  if (!hint) return null;
  const wanted = String(hint).trim();
  if (!wanted) return null;
  const exact = partnerFilesLower.get(wanted.toLowerCase());
  if (exact) return exact;
  const baseName = normalizeBaseName(wanted);
  return partnerFiles.find((f) => normalizeBaseName(f) === baseName) || null;
};

const initials = (name) => {
  const s = String(name || "").trim();
  if (!s) return "•";
  const words = s.replace(/["«»“”„]/g, "").split(/\s+/).filter(Boolean);
  const pickChars = [];
  for (const w of words) {
    const ch = w[0];
    if (!ch) continue;
    if (/[A-Za-zА-Яа-яІіЇїЄєҐґ0-9]/.test(ch)) pickChars.push(ch.toUpperCase());
    if (pickChars.length >= 2) break;
  }
  return pickChars.join("") || "•";
};

const partners = [
  { name: "Святошинський РВК у м. Києві", nameEn: "Sviatoshyn District Territorial Recruitment and Social Support Center in Kyiv", logoHint: "partner1-logo.png", url: "https://www.facebook.com/SviatoshynskyTCK/" },
  { name: 'Державна установа "Центр пробації"', nameEn: 'State Institution "Probation Center"', logoHint: "partner6-logo.png", url: "" },
  { name: 'Благодійна організація "Сила єдності"', nameEn: 'Charitable Organization "Power of Unity"', logoHint: "partner4-logo.png", url: "https://www.facebook.com/Syla.Ednosti/" },
  { name: 'Благодійний фонд "Наш промінь світла"', nameEn: 'Charitable Foundation "Our Ray of Light"', logoHint: "partner5-logo.png", url: "" },
  { name: 'Благодійний фонд "Слава Україні"', nameEn: 'Charitable Foundation "Glory to Ukraine"', logoHint: "partner9-logo.png", url: "https://glory2ukraine.rada.gov.ua/ua/" },
  { name: "Київська православна богословська академія", nameEn: "Kyiv Orthodox Theological Academy", logoHint: "partner17-logo.png", url: "https://kpba.edu.ua/" },
  { name: "Українська Асоціація Гуманітарного Розмінування", nameEn: "Ukrainian Association for Humanitarian Demining", logoHint: "partner7-logo.png", url: "https://deminingua.com/" },
  { name: "Військова частина А7297 Святошинська районна в м. Києві адміністрація", nameEn: "Military Unit A7297 and Sviatoshyn District Administration in Kyiv", logoHint: "", url: "" },
  { name: "Добровольче формування Територіальної громади м. Києва №10", nameEn: "Volunteer Formation of the Territorial Community of Kyiv No. 10", logoHint: "", url: "" },
  { name: 'Окремий підрозділ Добровольчого Формування Територіально громади м. Києва № 42 "Легіон Оболонь"', nameEn: 'Separate Unit of the Volunteer Formation of the Territorial Community of Kyiv No. 42 "Obolon Legion"', logoHint: "", url: "https://www.facebook.com/people/%D0%94%D0%BE%D0%B1%D1%80%D0%BE%D0%B2%D0%BE%D0%BB%D1%8C%D1%87%D0%B5-%D0%A4%D0%BE%D1%80%D0%BC%D1%83%D0%B2%D0%B0%D0%BD%D0%BD%D1%8F-%D0%9B%D0%B5%D0%B3%D1%96%D0%BE%D0%BD-%D0%9E%D0%B1%D0%BE%D0%BB%D0%BE%D0%BD%D1%8C/pfbid02M33rr5fJuYokVfiY41GpZLNr9z2TeRTGvZzqj7DNfoNDrLyu1YkqHztD9JP9KNfwl/" },
  { name: 'Громадська спілка "Святошинські маскувальні сіточки"', nameEn: 'Public Union "Sviatoshyn Camouflage Nets"', logoHint: "", url: "https://www.facebook.com/groups/1206167250190364/" },
  { name: 'Волонтерський гурт "Борщагівські Кікімори"', nameEn: 'Volunteer Group "Borshchahivka Kikimory"', logoHint: "", url: "" },
  { name: "Соціальний центр Перспектива Галаган і Нивок та захист прав учасників АТО", nameEn: 'Social Center "Perspektyva Halahan and Nyvky" and Protection of ATO Participants’ Rights', logoHint: "", url: "" },
  { name: 'Київська міська дитяча клінічна туберкульозна лікарня', nameEn: "Kyiv City Children's Clinical Tuberculosis Hospital", logoHint: "", url: "https://med.kyivcity.gov.ua/medportal/medview/174.html" },
  { name: `КНП КОР "Київський обласний центр ментального здоров'я"`, nameEn: 'Municipal Non-Profit Enterprise of Kyiv Regional Council "Kyiv Regional Mental Health Center"', logoHint: "", url: "https://kopnl.com.ua/" },
  { name: 'Комунальорганізація виконавчого органу київської міської ради (Київської міської державної адміністрації) "Муніцпальна охорона"', nameEn: 'Municipal Organization of the Executive Body of Kyiv City Council (Kyiv City State Administration) "Municipal Guard"', logoHint: "", url: "https://kyivcity.gov.ua/bezpeka_ta_pravoporiadok/munitsipalna_okhorona/" },
  { name: 'ГО "Святошинська районна в м. Києві організація інвалідів війни, збройних сил та учасників бойових дій"', nameEn: 'NGO "Sviatoshyn District Organization in Kyiv of Disabled War Veterans, Armed Forces Members and Combatants"', logoHint: "", url: "" },
].map((p) => {
  const file = resolveLogoFile(p.logoHint);
  const logo = file ? asset(`/images/partners/${file}`) : null;
  return { ...p, logo };
});

// Останні оновлення (2 картки)
const latestNews = [
  {
    title: "АВКУ долучилася до благодійного ярмарку на підтримку батальйону «Свобода»",
    titleEn: "AVKU joined a charity fair supporting the Svoboda battalion",
    dateISO: "2026-06-14",
    dateLabel: "14 червня 2026",
    dateLabelEn: "June 14, 2026",
    text: "У парку «Відрадний» збирали кошти на FPV-дрони для батальйону «Свобода» бригади НГУ «Рубіж».",
    textEn: "In Vidradnyi Park, funds were raised for FPV drones for the Svoboda battalion of the Rubizh National Guard brigade.",
    anchor: "2026-06-14-solomianskyi-charity-fair",
  },
  {
    title: "Передали EcoFlow для 34-ї окремої бригади морської піхоти",
    titleEn: "EcoFlow delivered for the 34th Separate Marine Brigade",
    dateISO: "2026-05-15",
    dateLabel: "15 травня 2026",
    dateLabelEn: "May 15, 2026",
    text: "Потужна підзарядна станція забезпечить безперебійну роботу та зв'язок мінометного батальйону.",
    textEn: "The high-capacity charging station will help keep the mortar battalion’s work and communications running without interruption.",
    anchor: "2026-05-15-34-marine-brigade-ecoflow",
  },
];

// JSON-LD
const orgName = en
  ? "Association of Volunteer Teams of Ukraine (AVKU)"
  : "ГС «Асоціація волонтерських команд України» (АВКУ)";
const orgDescription = en
  ? "AVKU is a union of volunteer teams and civic organizations of Ukraine that coordinates support for the Armed Forces, humanitarian aid for those affected, and recovery initiatives."
  : "ГС «АВКУ» — об'єднання волонтерських команд та громадських організацій України, що координує допомогу ЗСУ, гуманітарну підтримку постраждалим та ініціативи з відновлення.";

const orgJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${SITE_URL}/#organization`,
      name: orgName,
      alternateName: en ? "АВКУ" : "AVKU",
      url: `${SITE_URL}/`,
      logo: `${SITE_URL}/logo.png`,
      description: orgDescription,
      foundingDate: "2022",
      contactPoint: [
        {
          "@type": "ContactPoint",
          telephone: "+380636777050",
          contactType: "customer support",
          areaServed: "UA",
          email: "volunteer_ukraine@ukr.net",
        },
      ],
      address: {
        "@type": "PostalAddress",
        streetAddress: en ? "58-A Zodchykh St" : "вул. Зодчих, 58-а",
        addressLocality: en ? "Kyiv" : "Київ",
        postalCode: "03170",
        addressCountry: "UA",
      },
      sameAs: [
        "https://www.youtube.com/@avkuorg",
        "https://www.facebook.com/share/g/1ErStWMBoP/",
      ],
    },
    {
      "@type": "WebSite",
      "@id": `${SITE_URL}/#website`,
      url: `${SITE_URL}/`,
      name: orgName,
      inLanguage: en ? "en" : "uk",
      publisher: { "@id": `${SITE_URL}/#organization` },
    },
  ],
};
---

<Base
  lang={lang}
  title={t("meta_home_title")}
  description={t("meta_home_desc")}
  path="/"
>
  <Fragment slot="head">
    <meta name="author" content={orgName} />
    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
  </Fragment>

  <!-- HERO -->
  <section class="hero">
    <div class="container hero-content">
      <h1 class="hero-header" data-translate="hero_header">{t("hero_header")}</h1>
      <p class="hero-slogan" data-translate="hero_slogan">{t("hero_slogan")}</p>
      <p data-translate="hero_text">{t("hero_text")}</p>

      <div class="hero-actions" style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
        <a href={link("/donate")} class="btn" aria-label={t("home_hero_donate_aria")} data-translate="cta_support">{t("cta_support")}</a>
        <a href={link("/join")} class="btn" aria-label={t("home_hero_volunteer_aria")} data-translate="cta_become_volunteer">{t("cta_become_volunteer")}</a>
        <a href={link("/reports")} class="btn" aria-label={t("home_hero_reports_aria")} data-translate="cta_reports_transparency">{t("cta_reports_transparency")}</a>
      </div>

      <p style="margin-top:16px; font-size:0.95rem; opacity:0.9;" data-translate="home_hero_note">{t("home_hero_note")}</p>
    </div>
  </section>

  <!-- URGENT NEEDS -->
  <section class="activities">
    <div class="container">
      <h2 class="section-title" data-translate="urgent_needs_title">{t("urgent_needs_title")}</h2>

      <div class="activities-grid">
        {urgentNeeds.map((n) => (
          <div class="activity-card">
            <h3 data-translate={n.titleKey}>{t(n.titleKey)}</h3>
            <p data-translate={n.descKey}>{t(n.descKey)}</p>
            <div style="margin-top:16px;">
              <a class="btn" href={link(n.href)} aria-label={`${t("home_support_prefix")} ${t(n.titleKey)}`} data-translate={n.ctaKey}>{t(n.ctaKey)}</a>
            </div>
          </div>
        ))}
      </div>

      <div class="view-more-container" style="margin-top:24px;">
        <a href={link("/donate")} class="btn" aria-label={t("home_urgent_more_aria")} data-translate="urgent_needs_more_cta">{t("urgent_needs_more_cta")}</a>
      </div>
    </div>
  </section>

  <!-- ACTIVITIES -->
  <section class="activities">
    <div class="container">
      <h2 class="section-title" data-translate="activities_title">{t("activities_title")}</h2>

      <div class="activities-grid">
        {activities.map((a) => (
          <div class="activity-card">
            <h3 data-translate={a.titleKey}>{t(a.titleKey)}</h3>
            <p data-translate={a.descKey}>{t(a.descKey)}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RESULTS + PHOTO REPORTS + TESTIMONIALS -->
  <section class="trust-block">
    <div class="container">
      <h2 class="section-title" data-translate="results_title">{t("results_title")}</h2>

      <div class="counters-container">
        {counters.map((c) => (
          <div class="counter-item">
            <div class="counter" data-target={String(c.target)}>{formatCounter(c.target)}</div>
            <p class="counter-label" data-translate={c.labelKey}>{t(c.labelKey)}</p>
          </div>
        ))}
      </div>

      <div class="view-more-container" style="margin-top:0;">
        <a href={link("/reports")} class="btn" aria-label={t("home_reports_aria")} data-translate="cta_view_reports">{t("cta_view_reports")}</a>
      </div>

      <h2 class="section-title" data-translate="photo_reports_title">{t("photo_reports_title")}</h2>

      <div class="photo-gallery">
        {photoReports.map((r) => (
          <a href={r.href} class="gallery-card" aria-label={r.text}>
            <img src={asset(r.img)} alt={r.alt} loading="lazy" decoding="async" />
            <div class="card-overlay">
              <p>{r.text}</p>
            </div>
          </a>
        ))}
      </div>

      <div class="view-more-container">
        <a href={link("/reports")} class="btn" aria-label={t("home_photos_aria")} data-translate="cta_more_photos">{t("cta_more_photos")}</a>
      </div>

      <h2 class="section-title" data-translate="testimonials_title">{t("testimonials_title")}</h2>

      <div class="testimonials-container">
        {testimonials.map((tm) => (
          <div class="testimonial">
            <blockquote>"{pick(tm.quote, tm.quoteEn)}"</blockquote>
            <cite>{pick(tm.cite, tm.citeEn)}</cite>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PARTNERS -->
  <section class="partners">
    <div class="container">
      <h2 data-translate="partners_header">{t("partners_header")}</h2>

      <div class="partners-list">
        {partners.map((p) => (
          <div class="partner">
            {p.logo ? (
              <img
                src={p.logo}
                alt={pick(`Логотип партнера: ${p.name}`, `Partner logo: ${p.nameEn}`)}
                loading="lazy"
                decoding="async"
                style="width:100%; height:96px; object-fit:contain; display:block;"
              />
            ) : (
              <div
                aria-hidden="true"
                style="width:100%; height:96px; display:flex; align-items:center; justify-content:center; border:1px solid rgba(255,255,255,0.12); border-radius:12px; opacity:0.9; font-weight:700; letter-spacing:0.04em;"
                title={t("home_logo_missing")}
              >
                <span>{pick(initials(p.name), initials(p.nameEn))}</span>
              </div>
            )}

            <h3>{pick(p.name, p.nameEn)}</h3>

            {p.url ? (
              <a href={p.url} target="_blank" rel="noopener noreferrer" data-translate="visit_site">{t("visit_site")}</a>
            ) : (
              <span style="opacity:0.65;" data-translate="site_missing">{t("site_missing")}</span>
            )}
          </div>
        ))}
      </div>

      <div class="view-more-container">
        <a href={link("/about")} class="btn" aria-label={t("home_partners_about_aria")} data-translate="about_btn">{t("about_btn")}</a>
      </div>
    </div>
  </section>

  <!-- LATEST NEWS -->
  <section class="news">
    <div class="container">
      <h2 data-translate="news_header">{t("news_header")}</h2>

      <div class="news-items">
        {latestNews.map((n) => (
          <article class="news-item">
            <h3>{pick(n.title, n.titleEn)}</h3>

            <p class="news-meta">
              <time datetime={n.dateISO} aria-label={pick(n.dateLabel, n.dateLabelEn)}>{pick(n.dateLabel, n.dateLabelEn)}</time>
            </p>

            <p>{pick(n.text, n.textEn)}</p>

            <a href={`${link("/news")}#${n.anchor}`} aria-label={pick(n.title, n.titleEn)} data-translate="cta_details">{t("cta_details")}</a>
          </article>
        ))}
      </div>

      <div class="view-more-container">
        <a href={link("/news")} class="btn" aria-label={t("home_allnews_aria")} data-translate="cta_all_news">{t("cta_all_news")}</a>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="activities">
    <div class="container">
      <h2 class="section-title" data-translate="home_final_title">{t("home_final_title")}</h2>

      <div class="activities-grid">
        <div class="activity-card">
          <h3 data-translate="shared_support_donation_title">{t("shared_support_donation_title")}</h3>
          <p data-translate="shared_support_donation_desc">{t("shared_support_donation_desc")}</p>
          <div style="margin-top:16px;">
            <a class="btn" href={link("/donate")} aria-label={t("home_hero_donate_aria")} data-translate="cta_support">{t("cta_support")}</a>
          </div>
        </div>

        <div class="activity-card">
          <h3 data-translate="shared_become_volunteer_title">{t("shared_become_volunteer_title")}</h3>
          <p data-translate="home_final_volunteer_desc">{t("home_final_volunteer_desc")}</p>
          <div style="margin-top:16px;">
            <a class="btn" href={link("/join")} aria-label={t("home_hero_volunteer_aria")} data-translate="cta_fill_form">{t("cta_fill_form")}</a>
          </div>
        </div>

        <div class="activity-card">
          <h3 data-translate="home_final_partner_title">{t("home_final_partner_title")}</h3>
          <p data-translate="home_final_partner_desc">{t("home_final_partner_desc")}</p>
          <div style="margin-top:16px;">
            <a class="btn" href={link("/contacts")} aria-label={t("cta_contact")} data-translate="cta_contact">{t("cta_contact")}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Лічильники -->
  <script is:inline data-astro-rerun define:vars={{ numberLocale }}>
    (function () {
      function run() {
        const els = Array.from(document.querySelectorAll('.counter[data-target]'));
        if (!els.length) return;

        const prefersReduced =
          window.matchMedia?.('(prefers-reduced-motion: reduce)').matches ?? false;

        const format = (n) => {
          try { return Number(n).toLocaleString(numberLocale); }
          catch { return String(n); }
        };

        const setFinal = (el) => {
          const target = Number(el.getAttribute('data-target') || '0');
          el.textContent = Number.isFinite(target) && target > 0 ? format(target) : '-';
        };

        if (prefersReduced || !('IntersectionObserver' in window)) {
          els.forEach(setFinal);
          return;
        }

        const animate = (el) => {
          if (el.dataset.animated === '1') return;
          el.dataset.animated = '1';

          const target = Number(el.getAttribute('data-target') || '0');
          if (!Number.isFinite(target) || target <= 0) {
            el.textContent = '-';
            return;
          }

          const duration = 1100;
          const start = performance.now();

          function tick(now) {
            const t = Math.min(1, (now - start) / duration);
            const eased = 1 - Math.pow(1 - t, 3);
            const value = Math.floor(target * eased);
            el.textContent = format(value);
            if (t < 1) requestAnimationFrame(tick);
            else el.textContent = format(target);
          }

          requestAnimationFrame(tick);
        };

        const io = new IntersectionObserver((entries, obs) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              animate(e.target);
              obs.unobserve(e.target);
            }
          }
        }, { threshold: 0.2 });

        els.forEach((el) => io.observe(el));
      }

      document.addEventListener('astro:page-load', run);

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run, { once: true });
      } else {
        run();
      }
    })();
  </script>
</Base>
