---
// src/components/pages/ContactsPage.astro
import Base from "../../layouts/Base.astro";
import "../../styles/pages/contacts.css";
import { useTranslations, type Lang } from "../../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props as Props;
const t = useTranslations(lang);

const addressLines = t("address_text").split("\n");
---

<Base
  lang={lang}
  title={t("meta_contacts_title")}
  description={t("meta_contacts_desc")}
  path="/contacts"
>
  <Fragment slot="head">
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
  </Fragment>

  <div class="contacts-page">
    <section class="contact-info">
      <div class="container">
        <h1 class="section-title" data-translate="contact_title">{t("contact_title")}</h1>

        <div class="contact-grid">
          <div class="contact-card">
            <div class="contact-icon" aria-hidden="true">
              <i class="fa-solid fa-location-dot"></i>
            </div>
            <h3 data-translate="address_title">{t("address_title")}</h3>
            <p data-translate="address_text">
              {addressLines.map((line, i) => (
                <Fragment>{i > 0 && <br />}{line}</Fragment>
              ))}
            </p>
          </div>

          <div class="contact-card">
            <div class="contact-icon" aria-hidden="true">
              <i class="fa-solid fa-phone"></i>
            </div>
            <h3 data-translate="phones_title">{t("phones_title")}</h3>
            <p>
              <a href="tel:+380688473401">+38 (068) 847-34-01</a><br />
              <a href="tel:+380636777050">+38 (063) 677-70-50</a>
            </p>
          </div>

          <div class="contact-card">
            <div class="contact-icon" aria-hidden="true">
              <i class="fa-solid fa-envelope"></i>
            </div>
            <h3 data-translate="email_title">{t("email_title")}</h3>
            <p>
              <a href="mailto:volunteer_ukraine@ukr.net">volunteer_ukraine@ukr.net</a><br />
            </p>
          </div>

          <div class="contact-card">
            <div class="contact-icon" aria-hidden="true">
              <i class="fa-brands fa-facebook-f"></i>
            </div>
            <h3 data-translate="facebook_title">{t("facebook_title")}</h3>
            <p>
              <a
                href="https://www.facebook.com/groups/555103805361838"
                target="_blank"
                rel="noopener noreferrer"
              >
                Facebook
              </a>
              <br />
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="contact-form">
      <div class="container">
        <div class="form-wrapper">
          <h2 data-translate="write_title">{t("write_title")}</h2>

          <form id="contactForm" action="/api/contact" method="post" data-async-form data-form-type="contact">
            <div class="form-group">
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder=" "
                autocomplete="name"
              />
              <label for="name" data-translate="name_label">{t("name_label")}</label>
            </div>

            <div class="form-group">
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder=" "
                autocomplete="email"
                inputmode="email"
              />
              <label for="email" data-translate="email_label">{t("email_label")}</label>
            </div>

            <div class="form-group">
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder=" "
              ></textarea>
              <label for="message" data-translate="message_label">{t("message_label")}</label>
            </div>

            <button type="submit" class="btn btn-primary" data-translate="send_button">
              {t("send_button")}
              <i class="fa-solid fa-paper-plane" aria-hidden="true"></i>
            </button>

            <p class="form-status" data-form-status role="status" aria-live="polite" hidden></p>
          </form>
        </div>
      </div>
    </section>

    <section class="map">
      <div class="container">
        <h2 data-translate="map_header">{t("map_header")}</h2>

        <iframe
          title="Google Map"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2540.652592073314!2d30.36245731592181!3d50.43072357947188!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTDCsDI1JzUwLjYiTiAzMMKwMjEnNTIuNyJF!5e0!3m2!1suk!2sua!4v1677654321098!5m2!1suk!2sua"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </section>
  </div>
</Base>
