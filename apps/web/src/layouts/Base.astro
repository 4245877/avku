---
import "../styles/tokens.css";
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import {
  SITE_URL,
  absoluteUrl,
  alternates,
  htmlLangAttr,
  ogLocale,
  oppositeLang,
  useTranslations,
  type Lang,
} from "../i18n/ui";

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
  /** Логічний шлях без локалі/бази: "/", "/about", "/news"… */
  path?: string;
  /** Абсолютний або відносний шлях до OG-зображення (необов'язково). */
  image?: string;
  noindex?: boolean;
}

const {
  lang = "uk",
  title,
  description,
  path = "/",
  image,
  noindex = false,
} = Astro.props as Props;

const t = useTranslations(lang);

const base = import.meta.env.BASE_URL;
const join = (p: string) => {
  const clean = String(p).replace(/^\//, "");
  const baseFixed = base.endsWith("/") ? base : base + "/";
  return `${baseFixed}${clean}`;
};

const pageTitle = title ?? t("Association");
const pageDescription = description ?? t("site_description");

const logoPath = join("/logo.png");
const logoUrl = new URL(logoPath, SITE_URL).toString();
const ogImage = image
  ? new URL(image, SITE_URL).toString()
  : logoUrl;

const canonical = absoluteUrl(path, lang);
const altLinks = alternates(path);
const ogAltUrl = absoluteUrl(path, oppositeLang(lang));

const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "АВКУ",
  alternateName:
    lang === "uk"
      ? "Асоціація Волонтерських Команд України"
      : "Association of Volunteer Teams of Ukraine",
  url: SITE_URL,
  logo: logoUrl,
  description: pageDescription,
};
---

<!doctype html>
<html lang={htmlLangAttr(lang)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow" />}

    <title>{pageTitle}</title>

    <link rel="canonical" href={canonical} />

    <!-- база для public/scripts/app.js (редірект кореня на обрану локаль) -->
    <meta name="app-base" content={base} />

    <!-- hreflang: uk / en / x-default -->
    {altLinks.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    <!-- favicon / browser tab icon -->
    <link rel="icon" type="image/png" href={logoPath} />
    <link rel="shortcut icon" type="image/png" href={logoPath} />
    <link rel="apple-touch-icon" href={logoPath} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="АВКУ" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={t("og_image_alt")} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale(lang)} />
    <meta property="og:locale:alternate" content={ogLocale(oppositeLang(lang))} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href={join("/sitemap.xml")} />

    <!-- Google structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationJsonLd)}
    />

    <slot name="head" />

    <script src={join("/scripts/app.js")} defer></script>
    <script src={join("/scripts/forms.js")} defer></script>
  </head>

  <body>
    <Header lang={lang} path={path} />

    <main id="content" class="main">
      <slot />
    </main>

    <Footer lang={lang} />
  </body>
</html>
