---
import Base from "../layouts/Base.astro";
import "../styles/pages/news.css";

import { getCollection } from "astro:content";

const lang = "uk";

// Для GitHub Pages (base=/avku).
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const encodePath = (p) => p.split("/").map((seg) => encodeURIComponent(seg)).join("/");
const url = (path) => {
  if (!path) return "#";
  if (path.startsWith("http")) return path;
  const normalizedPath = path.startsWith("/") ? path : `/${path}`;
  return `${base}${encodePath(normalizedPath)}`;
};

// SEO
const siteUrl = "https://avku.org";
const canonicalUrl = `${siteUrl}/news`;

const title = "Новини — АВКУ | допомога ЗСУ, гуманітарні ініціативи, партнерства";
const description =
  "Офіційні оновлення АВКУ: передача допомоги, гуманітарні ініціативи, партнерства, події та відзнаки. Долучайся: донат, волонтерство, партнерство.";

// Категорії (для фільтра)
const categories = [
  { key: "all", label: "Всі", labelEn: "All" },
  { key: "zsu", label: "Підтримка ЗСУ", labelEn: "Support for the Armed Forces" },
  { key: "humanitarian", label: "Гуманітарна допомога", labelEn: "Humanitarian aid" },
  { key: "partnerships", label: "Партнерства", labelEn: "Partnerships" },
  { key: "community", label: "Освіта / громада", labelEn: "Education / community" },
  { key: "awards", label: "Відзнаки", labelEn: "Recognition" },
  { key: "events", label: "Події", labelEn: "Events" }
];

const categoryMap = Object.fromEntries(categories.map((c) => [c.key, c.label]));
const categoryMapEn = Object.fromEntries(categories.map((c) => [c.key, c.labelEn]));

const formatDateUk = (iso) => {
  const value = String(iso ?? "");
  const date = new Date(`${value}T00:00:00`);
  if (Number.isNaN(date.getTime())) return value;

  return new Intl.DateTimeFormat("uk-UA", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);
};

const formatDateEn = (iso) => {
  const value = String(iso ?? "");
  const date = new Date(`${value}T00:00:00`);
  if (Number.isNaN(date.getTime())) return value;

  return new Intl.DateTimeFormat("en", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(date);
};

const newsTranslations = {
  "2026-06-14-solomianskyi-charity-fair": {
    title: "AVKU joined a charity fair supporting the Svoboda battalion",
    excerpt:
      "A charity fair was held in Vidradnyi Park, with proceeds going toward FPV drones for the Svoboda battalion of the Rubizh National Guard brigade.",
    imgAlt: "Participants of the charity fair in Vidradnyi Park with an FPV drone",
    sourceLabel: "Bohdan Kolodiy on Facebook",
  },
  "2026-05-15-34-marine-brigade-ecoflow": {
    title: "EcoFlow delivered for the 34th Separate Marine Brigade",
    excerpt:
      "A high-capacity EcoFlow charging station was delivered to the mortar battalion of the 34th Separate Marine Brigade for uninterrupted work and communications.",
    imgAlt: "EcoFlow charging station delivered for the 34th Separate Marine Brigade",
    sourceLabel: "AVKU website",
  },
  "2026-02-12-kharkiv-16-corps-5201": {
    title: "Support for defenders in Kharkiv region: aid for the 16th Army Corps, military unit 5201",
    excerpt:
      "A generator, FPV drones, camouflage nets, and other essentials were delivered to the 16th Army Corps, military unit 5201.",
    imgAlt: "Aid delivery to the 16th Army Corps, military unit 5201, Kharkiv region",
    sourceLabel: "AVKU website",
  },
};

const newsEntries = await getCollection("news", ({ data }) => data.draft !== true);

const news = newsEntries
  .map((entry) => {
    const id = entry.id.replace(/\/index$/, "");
    const data = entry.data;
    const tr = newsTranslations[id] || {};

    return {
      id,
      title: data.title,
      titleEn: tr.title || data.title,
      dateISO: data.dateISO,
      dateLabel: data.dateLabel || formatDateUk(data.dateISO),
      dateLabelEn: formatDateEn(data.dateISO),
      categoryKey: data.categoryKey || "zsu",
      categoryLabel: categoryMap[data.categoryKey] || "Новини",
      categoryLabelEn: categoryMapEn[data.categoryKey] || "News",
      excerpt: data.excerpt,
      excerptEn: tr.excerpt || data.excerpt,
      href: data.href || `/news#${id}`,
      img: data.img || "",
      imgAlt: data.imgAlt || data.title,
      imgAltEn: tr.imgAlt || tr.title || data.imgAlt || data.title,
      sourceLabel: data.sourceLabel || "Сайт АВКУ",
      sourceLabelEn: tr.sourceLabel || "AVKU website",
    };
  })
  .sort((a, b) => Date.parse(b?.dateISO || "") - Date.parse(a?.dateISO || ""));

const featured = news[0] ?? null;

// Документи
const documents = [
  {
    title: "Потужний волонтерський рух у визвольній війні від військової агресії рф…",
    titleEn: "A powerful volunteer movement in the liberation war against Russian military aggression...",
    label: "PDF · грудень 2024 (архів)",
    labelEn: "PDF · December 2024 (archive)",
    href: "https://avku.org/publications/%D0%92%D0%9E%D0%9B%D0%9E%D0%9D%D0%A2%D0%95%D0%A0%D0%A1%D0%AC%D0%9A%D0%98%D0%99_%D0%A0%D0%A3%D0%A5_%D1%81%D1%82_%D0%9A%D0%BE%D0%BB%D0%BE%D0%B4%D1%96%D0%B9%2C%D0%93%D0%BE%D0%BB%D0%BE%D0%B2%D0%B0%D1%87.pdf"
  }
];

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url: canonicalUrl,
  isPartOf: {
    "@type": "WebSite",
    name: "АВКУ — Асоціація волонтерських команд України",
    url: siteUrl
  },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: news.slice(0, 20).map((n, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `${canonicalUrl}#${n.id}`,
      name: n.title
    }))
  }
};
---

<Base lang={lang} title={title} description={description}>
  <Fragment slot="head">
    <meta name="author" content="ГС «Асоціація Волонтерських Команд України» (АВКУ)" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:locale" content="uk_UA" />
    <meta property="og:site_name" content="АВКУ — Асоціація Волонтерських Команд України" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}/logo.png`} />
    <meta property="og:image:alt" content="Логотип АВКУ" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/logo.png`} />

    <link rel="sitemap" type="application/xml" title="Sitemap" href={url("/sitemap.xml")} />

    <script type="application/ld+json" is:inline>
      {JSON.stringify(orgJsonLd)}
    </script>
  </Fragment>

  <section class="hero">
    <div class="container hero-content">
      <h1 class="hero-header" data-translate-en="News">Новини</h1>
      <p class="hero-slogan" data-translate-en="Updates about aid, partnerships, events, and reporting">
        Оновлення про допомогу, партнерства, події та звітність
      </p>

      <p class="muted" data-translate-en="Here we publish short summaries of what has been done. Please support us with a donation or join as a volunteer so we can do more.">
        Тут ми публікуємо короткі підсумки того, що зроблено. Якщо не трудно,
        підтримай донатом або долучайся як волонтер — так ми зможемо робити більше.
      </p>

      <div class="hero-actions" style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
        <a href={url("/donate")} class="btn" aria-label="Перейти на сторінку донату" data-translate-en="Support" data-translate-en-aria-label="Go to the donation page">Підтримати</a>
        <a href={url("/join")} class="btn" aria-label="Перейти на сторінку для волонтерів" data-translate-en="Become a volunteer" data-translate-en-aria-label="Go to the volunteer page">Стати волонтером</a>
        <a href={url("/reports")} class="btn" aria-label="Перейти до звітів" data-translate-en="Reports / Transparency" data-translate-en-aria-label="Go to reports">Звіти / Прозорість</a>
      </div>
    </div>
  </section>

  {featured ? (
    <section class="container" style="margin-top:24px;">
      <article class="featured" aria-label="Головна новина" data-translate-en-aria-label="Featured news">
        {featured.img ? (
          <img
            src={url(featured.img)}
            alt={featured.imgAlt || featured.title}
            data-translate-en-alt={featured.imgAltEn}
            loading="lazy"
            decoding="async"
          />
        ) : null}

        <div class="body">
          <div class="meta">
            <span class="pill" data-translate-en={featured.categoryLabelEn}>{featured.categoryLabel || categoryMap[featured.categoryKey] || "Новини"}</span>
            <time datetime={featured.dateISO} data-translate-en={featured.dateLabelEn}>{featured.dateLabel || featured.dateISO}</time>
            {featured.sourceLabel ? <span style="opacity:.8;" data-translate-en={`· ${featured.sourceLabelEn}`}>· {featured.sourceLabel}</span> : null}
          </div>

          <h2 style="margin:10px 0 8px;" data-translate-en={featured.titleEn}>{featured.title}</h2>
          <p style="opacity:.95;" data-translate-en={featured.excerptEn}>{featured.excerpt}</p>

          <a href={url(featured.href)} class="btn" style="margin-top:14px;" aria-label={featured.title} data-translate-en="Details" data-translate-en-aria-label={featured.titleEn}>
            Детальніше
          </a>
        </div>
      </article>
    </section>
  ) : null}

  <section class="container" style="margin-top:22px; margin-bottom:30px;">
    <div class="news-layout">
      <div>
        <h2 class="section-title" data-translate-en="News feed">Стрічка новин</h2>

        <div class="news-controls" role="region" aria-label="Фільтри новин" data-translate-en-aria-label="News filters">
          <div>
            <label for="newsSearch" data-translate-en="Search">Пошук</label><br />
            <input
              id="newsSearch"
              type="search"
              placeholder="Наприклад: дрони, меморандум…"
              data-translate-en-placeholder="For example: drones, memorandum..."
              autocomplete="off"
            />
          </div>

          <div>
            <label for="newsCategory" data-translate-en="Category">Категорія</label><br />
            <select id="newsCategory" aria-label="Вибрати категорію" data-translate-en-aria-label="Choose a category">
              {categories.map((c) => (
                <option value={c.key} data-translate-en={c.labelEn}>{c.label}</option>
              ))}
            </select>
          </div>

          <div>
            <label for="newsSort" data-translate-en="Sort">Сортування</label><br />
            <select id="newsSort" aria-label="Вибрати сортування" data-translate-en-aria-label="Choose sorting">
              <option value="new" data-translate-en="Newest first">Спочатку нові</option>
              <option value="old" data-translate-en="Oldest first">Спочатку старі</option>
            </select>
          </div>
        </div>

        <p class="news-count" id="newsCount" aria-live="polite"></p>

        <div id="noResults" class="no-results" role="status" aria-live="polite" data-translate-en="Nothing found. Please try another query or choose “All”.">
          Нічого не знайдено. Спробуй, будь ласка, інший запит або обери «Всі».
        </div>

        <div class="news-items" id="newsList" style="display:grid; gap:14px;">
          {news.map((n) => (
            <article
              id={n.id}
              class="news-card"
              data-news-card="1"
              data-cat={n.categoryKey || ""}
              data-date={n.dateISO || ""}
              data-title={`${n.title || ""} ${n.titleEn || ""}`.toLowerCase()}
              data-text={`${n.excerpt || ""} ${n.excerptEn || ""}`.toLowerCase()}
            >
              {n.img ? (
                <a href={url(n.href)} aria-label={`Відкрити: ${n.title}`} data-translate-en-aria-label={`Open: ${n.titleEn}`}>
                  <img
                    src={url(n.img)}
                    alt={n.imgAlt || n.title}
                    data-translate-en-alt={n.imgAltEn}
                    loading="lazy"
                    decoding="async"
                    style="width:100%; height:auto; display:block;"
                  />
                </a>
              ) : null}

              <div class="body">
                <div class="meta">
                  <span class="pill" data-translate-en={n.categoryLabelEn}>{n.categoryLabel || categoryMap[n.categoryKey] || "Новини"}</span>
                  <time datetime={n.dateISO} aria-label={n.dateLabel || n.dateISO} data-translate-en={n.dateLabelEn} data-translate-en-aria-label={n.dateLabelEn}>
                    {n.dateLabel || n.dateISO}
                  </time>
                  {n.sourceLabel ? <span style="opacity:.8;" data-translate-en={`· ${n.sourceLabelEn}`}>· {n.sourceLabel}</span> : null}
                </div>

                <h3 data-translate-en={n.titleEn}>{n.title}</h3>
                <p style="opacity:.95;" data-translate-en={n.excerptEn}>{n.excerpt}</p>

                <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:12px;">
                  <a href={url(n.href)} aria-label={`Відкрити: ${n.title}`} data-translate-en="Details" data-translate-en-aria-label={`Open: ${n.titleEn}`}>Детальніше</a>
                  {n.img ? (
                    <a href={url(n.href)} aria-label={`Переглянути фото: ${n.title}`} data-translate-en="Photo" data-translate-en-aria-label={`View photo: ${n.titleEn}`}>Фото</a>
                  ) : null}
                  <a href={`#${n.id}`} aria-label={`Скопіювати посилання на новину: ${n.title}`} data-translate-en="Link" data-translate-en-aria-label={`Copy link to news item: ${n.titleEn}`}>Лінк</a>
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="view-more-container" style="margin-top:16px;">
          <button
            id="loadMoreBtn"
            type="button"
            class="btn"
            aria-label="Показати ще новини"
            data-translate-en="Show more"
            data-translate-en-aria-label="Show more news"
          >
            Показати ще
          </button>
        </div>

        <noscript>
          <p
            class="muted small"
            style="margin-top:12px;"
            data-translate-en="Search and filters work better with JavaScript enabled."
          >
            Пошук і фільтри працюють краще з увімкненим JavaScript.
          </p>
        </noscript>
      </div>

      <aside style="display:grid; gap:14px;">
        <div class="aside-card">
          <h3 data-translate-en="Official channels">Офіційні канали</h3>
          <p class="muted small" style="margin:0 0 10px;" data-translate-en="We publish some materials on social media. Please subscribe: it also supports our work.">
            Частину матеріалів ми публікуємо у соцмережах. Якщо не трудно, підпишись — це теж підтримка.
          </p>
          <div style="display:flex; flex-direction:column; gap:10px;">
            <a
              class="btn-secondary"
              href="https://www.facebook.com/groups/555103805361838/?locale=ru_RU"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Відкрити Facebook-групу АВКУ"
              data-translate-en="Facebook group"
              data-translate-en-aria-label="Open the AVKU Facebook group"
            >
              Facebook-група
            </a>
            <a
              class="btn-secondary"
              href="https://avku.org/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Відкрити старий сайт АВКУ"
              data-translate-en="Old website (archive)"
              data-translate-en-aria-label="Open the old AVKU website"
            >
              Старий сайт (архів)
            </a>
            <a class="btn-secondary" href={url("/reports")} aria-label="Перейти до звітів" data-translate-en="Reports / Transparency" data-translate-en-aria-label="Go to reports">
              Звіти / Прозорість
            </a>
          </div>
        </div>

        <div class="aside-card">
          <h3 data-translate-en="How to help">Як допомогти</h3>
          <p class="muted small" style="margin:0 0 10px;" data-translate-en="Donation, volunteering, or partnership: every format is useful.">
            Донат, волонтерство або партнерство — будь-який формат корисний.
          </p>
          <div style="display:flex; flex-direction:column; gap:10px;">
            <a class="btn" href={url("/donate")} aria-label="Підтримати донатом" data-translate-en="Support" data-translate-en-aria-label="Support with a donation">Підтримати</a>
            <a class="btn-secondary" href={url("/join")} aria-label="Долучитися як волонтер або партнер" data-translate-en="Join" data-translate-en-aria-label="Join as a volunteer or partner">
              Долучитися
            </a>
          </div>
        </div>

        <div class="aside-card">
          <h3 data-translate-en="Documents / publications">Документи / публікації</h3>
          {documents?.length ? (
            <ul>
              {documents.map((d) => (
                <li style="margin-bottom:10px;">
                  <a href={d.href} target="_blank" rel="noopener noreferrer" aria-label={d.title} data-translate-en={d.titleEn} data-translate-en-aria-label={d.titleEn}>
                    {d.title}
                  </a>
                  <div class="muted small" data-translate-en={d.labelEn}>{d.label}</div>
                </li>
              ))}
            </ul>
          ) : (
            <p class="muted small" style="margin:0;" data-translate-en="There are currently no additional publications in this block.">Наразі немає додаткових публікацій у цьому блоці.</p>
          )}
          <div class="divider"></div>
          <p class="muted small" style="margin:0;" data-translate-en="If needed, this block can be moved to JSON/CMS later.">
            Якщо потрібно — цей блок легко винести в JSON/CMS.
          </p>
        </div>

        <div class="aside-card">
          <h3 data-translate-en="Tip">Порада</h3>
          <p class="muted small" style="margin:0;" data-translate-en="For quick search, try short keywords: “drones”, “memorandum”, “net”, “forum”.">
            Для швидкого пошуку спробуй короткі ключові слова: «дрони», «меморандум», «сітка», «форум».
          </p>
        </div>
      </aside>
    </div>
  </section>

  <script is:inline>
    {`
      (function () {
        const $ = (s) => document.querySelector(s);

        const listEl = $("#newsList");
        const countEl = $("#newsCount");
        const noResultsEl = $("#noResults");
        const searchEl = $("#newsSearch");
        const categoryEl = $("#newsCategory");
        const sortEl = $("#newsSort");
        const loadMoreBtn = $("#loadMoreBtn");

        if (!listEl || !countEl || !searchEl || !categoryEl || !sortEl || !loadMoreBtn) return;

        const allCards = Array.from(listEl.querySelectorAll('[data-news-card="1"]'));

        const INITIAL_VISIBLE = 8;
        const STEP = 8;

        let visibleLimit = INITIAL_VISIBLE;

        const norm = (s) => (s || "").toString().trim().toLowerCase();
        const currentLang = () => {
          try { return localStorage.getItem("avku_lang") || document.documentElement.lang || "uk"; }
          catch { return document.documentElement.lang || "uk"; }
        };

        const parseDate = (iso) => {
          const t = Date.parse(iso || "");
          return Number.isFinite(t) ? t : 0;
        };

        function matches(card, query, catKey) {
          if (catKey && catKey !== "all") {
            if ((card.getAttribute("data-cat") || "") !== catKey) return false;
          }
          if (!query) return true;

          const title = card.getAttribute("data-title") || "";
          const text = card.getAttribute("data-text") || "";
          return title.includes(query) || text.includes(query);
        }

        function render() {
          const query = norm(searchEl.value);
          const cat = categoryEl.value;
          const sortVal = sortEl.value;

          // 1. Filter
          const filtered = allCards.filter(c => matches(c, query, cat));

          // 2. Sort
          filtered.sort((a, b) => {
            const da = parseDate(a.getAttribute("data-date"));
            const db = parseDate(b.getAttribute("data-date"));
            return sortVal === "old" ? da - db : db - da;
          });

          // 3. Update DOM
          allCards.forEach(c => {
             c.style.display = "none";
          });

          const toShow = filtered.slice(0, visibleLimit);
          toShow.forEach(c => {
            listEl.appendChild(c);
            c.style.display = "";
          });

          const total = filtered.length;
          if (total === 0) {
            countEl.textContent = "";
            noResultsEl.style.display = "block";
            loadMoreBtn.style.display = "none";
          } else {
            noResultsEl.style.display = "none";
            const visibleCount = toShow.length;
            countEl.textContent = currentLang() === "en"
              ? \`Shown \${visibleCount} of \${total}\`
              : \`Показано \${visibleCount} із \${total}\`;

            if (visibleCount < total) {
              loadMoreBtn.style.display = "inline-flex";
            } else {
              loadMoreBtn.style.display = "none";
            }
          }
        }

        searchEl.addEventListener("input", () => {
          visibleLimit = INITIAL_VISIBLE;
          render();
        });
        categoryEl.addEventListener("change", () => {
          visibleLimit = INITIAL_VISIBLE;
          render();
        });
        sortEl.addEventListener("change", () => {
          visibleLimit = INITIAL_VISIBLE;
          render();
        });

        loadMoreBtn.addEventListener("click", () => {
          visibleLimit += STEP;
          render();
        });
        document.addEventListener("avku:language-change", render);

        render();
      })();
    `}
  </script>
</Base>
