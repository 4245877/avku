---
// src/pages/events.astro
import Base from "../layouts/Base.astro";
import "../styles/pages/events.css";

const lang = "uk";
const title =
  "Події АВКУ — благодійні заходи, волонтерські майстерні, гуманітарні виїзди";
const description =
  "Календар подій та форматів АВКУ: благодійні ярмарки, волонтерські майстерні, гуманітарні виїзди, освітні та партнерські заходи. Долучайся як волонтер або підтримай донатом.";

// Зовнішні посилання (офіційні)
const links = {
  facebookGroup: "https://www.facebook.com/groups/555103805361838/?locale=ru_RU",
};

// Контакти (зручно дублювати тут для сторінки подій)
const contacts = {
  city: "Київ",
  address: "вул. Зодчих, 58-а, 03170",
  phone1: "+38 (068) 847-34-01",
  phone2: "+38 (063) 677-70-50",
  email: "volunteer_ukraine@ukr.net",
};

// Формати подій (без “вигаданих” дат — лише те, що реально робить АВКУ)
const formats = [
  {
    key: "format_support",
    title: "Підтримка ЗСУ: закриття запитів підрозділів",
    desc:
      "Збір і передача необхідного спорядження, звʼязку, живлення, маскувальних засобів, технічних і побутових речей — за актуальними запитами.",
    tags: ["ЗСУ", "збір", "передача"],
    href: "/donate",
    cta: "Підтримати донатом",
  },
  {
    key: "format_humanitarian",
    title: "Гуманітарна допомога та відправки",
    desc:
      "Регулярні відправки продуктів, ліків і засобів гігієни для військових і цивільних, координація доставок та пакування.",
    tags: ["гуманітарка", "логістика"],
    href: "/join",
    cta: "Стати волонтером",
  },
  {
    key: "format_workshops",
    title: "Волонтерські майстерні",
    desc:
      "Спільні майстерні з виготовлення маскувальних сіток, окопних свічок та інших необхідних речей разом із волонтерами й партнерами.",
    tags: ["майстерня", "сітки", "свічки"],
    href: "/join",
    cta: "Долучитися",
  },
  {
    key: "format_charity",
    title: "Благодійні ярмарки та збори",
    desc:
      "Публічні благодійні заходи, ярмарки, події в громадах і закладах освіти — для підсилення зборів на потреби захисників.",
    tags: ["ярмарок", "збір"],
    href: "/donate",
    cta: "Підтримати",
  },
  {
    key: "format_education",
    title: "Освітні та культурні заходи",
    desc:
      "Зустрічі, лекції, патріотичні події, активності в громадах і навчальних закладах — щоб підтримувати єдність і мотивацію допомоги.",
    tags: ["освіта", "культура"],
    href: "/about",
    cta: "Дізнатися більше",
  },
  {
    key: "format_partnerships",
    title: "Партнерства та меморандуми",
    desc:
      "Співпраця з організаціями та ініціативами: меморандуми, спільні проєкти, форуми та координація допомоги.",
    tags: ["партнерство", "співпраця"],
    href: "/contacts",
    cta: "Зв’язатися",
  },
];

// Найближчі події: без фейкових анонсів — коректно виводимо “де дивитися”
const upcoming = [
  {
    title: "Анонси найближчих подій — у Facebook-групі АВКУ",
    dateLabel: "Оновлюється постами та закріпами",
    location: "Онлайн",
    desc:
      "Ми публікуємо актуальні анонси, місця зборів і потреби в нашій Facebook-спільноті. Натисни, щоб переглянути найсвіжіше.",
    href: links.facebookGroup,
    external: true,
    cta: "Відкрити Facebook-групу",
  },
];

// Архів (приклади подій, зафіксовані на старому сайті в “Галереї”)
const archive = [
  {
    id: "e-2025-12-12",
    dateISO: "2025-12-12",
    dateLabel: "12 грудня 2025",
    category: "ЗСУ / передача",
    title: "Передача допомоги для підрозділу ТрО (маскувальні сітки та інше)",
    desc:
      "Спільно з освітньою спільнотою підтримали підрозділ — передали маскувальні сітки та необхідні речі.",
    href: "/reports",
  },
  {
    id: "e-2025-12-05",
    dateISO: "2025-12-05",
    dateLabel: "5 грудня 2025",
    category: "Спільнота / форум",
    title: "Перший форум волонтерів до Міжнародного дня волонтера (Святошинський район)",
    desc:
      "Зустріч із друзями й партнерами: історії, підтримка та план наступних спільних справ.",
    href: "/reports",
  },
  {
    id: "e-2025-12-04",
    dateISO: "2025-12-04",
    dateLabel: "4 грудня 2025",
    category: "Освіта / зустріч",
    title: "Зустріч учнів і військових у ліцеї №281 (формат «какао з військовим»)",
    desc:
      "Тепла зустріч напередодні Дня волонтера й Святого Миколая — спілкування, підтримка, подарунки.",
    href: "/reports",
  },
  {
    id: "e-2025-06-15",
    dateISO: "2025-06-15",
    dateLabel: "15 червня 2025",
    category: "Гуманітарка / передача",
    title: "Передача гуманітарної допомоги підрозділу «Братство» (ГУР)",
    desc:
      "Чергове підсилення для тих, хто виконує завдання на напрямках.",
    href: "/reports",
  },
  {
    id: "e-2025-05-13",
    dateISO: "2025-05-13",
    dateLabel: "13 травня 2025",
    category: "Благодійність / ярмарок",
    title: "Благодійний ярмарок: зібрали кошти на 13 FPV-дронів",
    desc:
      "Спільний захід із партнерами та громадою — результатом стала закупівля FPV-дронів для підрозділів.",
    href: "/reports",
  },
  {
    id: "e-2025-05-31",
    dateISO: "2025-05-31",
    dateLabel: "31 травня 2025",
    category: "Партнерство / меморандум",
    title: "Підписання меморандуму з Київською православною богословською академією",
    desc:
      "Посилили співпрацю для спільних ініціатив і взаємної підтримки.",
    href: "/reports",
  },
  {
    id: "e-2025-02-05",
    dateISO: "2025-02-05",
    dateLabel: "5 лютого 2025",
    category: "Партнерство / форум",
    title: "Інтерактивний форум «10 років змін: пробація, що наближає до справедливості»",
    desc:
      "Подія на базі філії Центру пробації — обʼєднання дій і взаємна підтримка.",
    href: "/reports",
  },
  {
    id: "e-2025-02-19",
    dateISO: "2025-02-19",
    dateLabel: "19 лютого 2025",
    category: "Партнерство / меморандум",
    title: "Меморандум із соццентром «Перспектива Біличів і Новобіличів…»",
    desc:
      "Домовились про спільну роботу та координацію допомоги.",
    href: "/reports",
  },
  {
    id: "e-2025-02-04",
    dateISO: "2025-02-04",
    dateLabel: "4 лютого 2025",
    category: "Партнерство / меморандум",
    title: "Меморандум зі спілкою «Святошинські маскувальні сіточки»",
    desc:
      "Обʼєднання зусиль у волонтерських та благодійних сферах.",
    href: "/reports",
  },
];

// Фільтри (під архів)
const filterTabs = [
  { key: "all", label: "Усі" },
  { key: "ЗСУ / передача", label: "ЗСУ" },
  { key: "Гуманітарка / передача", label: "Гуманітарка" },
  { key: "Благодійність / ярмарок", label: "Ярмарки" },
  { key: "Освіта / зустріч", label: "Освіта" },
  { key: "Партнерство / меморандум", label: "Партнерства" },
  { key: "Спільнота / форум", label: "Форуми" },
];

const formatEnglish = {
  format_support: {
    titleEn: "Support for the Armed Forces: closing unit requests",
    descEn:
      "Collecting and delivering essential gear, communications, power solutions, camouflage, technical, and everyday items based on current requests.",
    tagsEn: ["Armed Forces", "fundraiser", "delivery"],
    ctaEn: "Donate",
  },
  format_humanitarian: {
    titleEn: "Humanitarian aid and shipments",
    descEn:
      "Regular shipments of food, medicine, and hygiene supplies for service members and civilians, including delivery coordination and packing.",
    tagsEn: ["humanitarian", "logistics"],
    ctaEn: "Become a volunteer",
  },
  format_workshops: {
    titleEn: "Volunteer workshops",
    descEn:
      "Joint workshops for camouflage nets, trench candles, and other essentials together with volunteers and partners.",
    tagsEn: ["workshop", "nets", "candles"],
    ctaEn: "Join",
  },
  format_charity: {
    titleEn: "Charity fairs and fundraisers",
    descEn:
      "Public charity events, fairs, community events, and education-based initiatives that strengthen fundraisers for defenders’ needs.",
    tagsEn: ["fair", "fundraiser"],
    ctaEn: "Support",
  },
  format_education: {
    titleEn: "Educational and cultural events",
    descEn:
      "Meetings, lectures, patriotic events, and community or school activities that support unity and motivation to help.",
    tagsEn: ["education", "culture"],
    ctaEn: "Learn more",
  },
  format_partnerships: {
    titleEn: "Partnerships and memorandums",
    descEn:
      "Cooperation with organizations and initiatives: memorandums, joint projects, forums, and aid coordination.",
    tagsEn: ["partnership", "cooperation"],
    ctaEn: "Contact us",
  },
};

const formatsView = formats.map((item) => ({ ...item, ...(formatEnglish[item.key] || {}) }));

const upcomingView = upcoming.map((item) => ({
  ...item,
  titleEn: "Upcoming event announcements are published in the AVKU Facebook group",
  dateLabelEn: "Updated through posts and pinned updates",
  locationEn: "Online",
  descEn:
    "We publish current announcements, gathering locations, and needs in our Facebook community. Click to see the latest updates.",
  ctaEn: "Open Facebook group",
}));

const archiveEnglish = {
  "e-2025-12-12": {
    dateLabelEn: "December 12, 2025",
    categoryEn: "Armed Forces / delivery",
    titleEn: "Aid delivery for a Territorial Defense unit (camouflage nets and other supplies)",
    descEn: "Together with the education community, we supported a unit by delivering camouflage nets and essential items.",
  },
  "e-2025-12-05": {
    dateLabelEn: "December 5, 2025",
    categoryEn: "Community / forum",
    titleEn: "First volunteer forum for International Volunteer Day in Sviatoshyn district",
    descEn: "A meeting with friends and partners: stories, support, and plans for the next joint efforts.",
  },
  "e-2025-12-04": {
    dateLabelEn: "December 4, 2025",
    categoryEn: "Education / meeting",
    titleEn: "Meeting of students and service members at Lyceum No. 281",
    descEn: "A warm meeting before Volunteer Day and St. Nicholas Day: communication, support, and gifts.",
  },
  "e-2025-06-15": {
    dateLabelEn: "June 15, 2025",
    categoryEn: "Humanitarian / delivery",
    titleEn: "Humanitarian aid delivery to the Bratstvo unit of Defence Intelligence",
    descEn: "Another boost for those carrying out missions in active areas.",
  },
  "e-2025-05-13": {
    dateLabelEn: "May 13, 2025",
    categoryEn: "Charity / fair",
    titleEn: "Charity fair: funds raised for 13 FPV drones",
    descEn: "A joint event with partners and the community that resulted in the purchase of FPV drones for units.",
  },
  "e-2025-05-31": {
    dateLabelEn: "May 31, 2025",
    categoryEn: "Partnership / memorandum",
    titleEn: "Memorandum signed with Kyiv Orthodox Theological Academy",
    descEn: "Cooperation was strengthened for joint initiatives and mutual support.",
  },
  "e-2025-02-05": {
    dateLabelEn: "February 5, 2025",
    categoryEn: "Partnership / forum",
    titleEn: "Interactive forum “10 years of change: probation that brings justice closer”",
    descEn: "An event hosted by the Probation Center branch, focused on coordinated action and mutual support.",
  },
  "e-2025-02-19": {
    dateLabelEn: "February 19, 2025",
    categoryEn: "Partnership / memorandum",
    titleEn: "Memorandum with the Perspektyva social center",
    descEn: "An agreement on joint work and coordination of assistance.",
  },
  "e-2025-02-04": {
    dateLabelEn: "February 4, 2025",
    categoryEn: "Partnership / memorandum",
    titleEn: "Memorandum with the Sviatoshyn Camouflage Nets union",
    descEn: "Uniting efforts in volunteer and charitable work.",
  },
};

const archiveView = archive.map((item) => ({ ...item, ...(archiveEnglish[item.id] || {}) }));

const filterEnglish = {
  all: "All",
  "ЗСУ / передача": "Armed Forces",
  "Гуманітарка / передача": "Humanitarian aid",
  "Благодійність / ярмарок": "Fairs",
  "Освіта / зустріч": "Education",
  "Партнерство / меморандум": "Partnerships",
  "Спільнота / форум": "Forums",
};

const filterTabsView = filterTabs.map((item) => ({
  ...item,
  labelEn: filterEnglish[item.key] || item.label,
}));

// JSON-LD: WebPage + ItemList (події як приклади)
const baseUrl = "https://avku.org";
const pageUrl = `${baseUrl}/events`;
const eventsJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${baseUrl}/#organization`,
      name: "ГС «Асоціація волонтерських команд України» (АВКУ)",
      alternateName: "AVKU",
      url: baseUrl,
      email: contacts.email,
      address: {
        "@type": "PostalAddress",
        addressLocality: contacts.city,
        streetAddress: contacts.address,
        addressCountry: "UA",
      },
      sameAs: [links.facebookGroup, "https://www.youtube.com/@avkuorg"],
    },
    {
      "@type": "CollectionPage",
      "@id": `${pageUrl}#webpage`,
      url: pageUrl,
      name: "Події та заходи АВКУ",
      description,
      isPartOf: { "@id": `${baseUrl}/#website` },
      about: { "@id": `${baseUrl}/#organization` },
      mainEntity: {
        "@type": "ItemList",
        itemListElement: archive.map((e, idx) => ({
          "@type": "ListItem",
          position: idx + 1,
          item: {
            "@type": "Event",
            "@id": `${pageUrl}#${e.id}`,
            name: e.title,
            startDate: e.dateISO,
            eventStatus: "https://schema.org/EventCompleted",
            eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
            location: {
              "@type": "Place",
              name: contacts.city,
              address: {
                "@type": "PostalAddress",
                addressLocality: contacts.city,
                addressCountry: "UA",
              },
            },
            organizer: { "@id": `${baseUrl}/#organization` },
          },
        })),
      },
    },
    {
      "@type": "WebSite",
      "@id": `${baseUrl}/#website`,
      url: baseUrl,
      name: "АВКУ — Асоціація волонтерських команд України",
      publisher: { "@id": `${baseUrl}/#organization` },
    },
  ],
};
---

<Base lang={lang} title={title} description={description}>
  <Fragment slot="head">
    <meta name="author" content="ГС «Асоціація волонтерських команд України» (АВКУ)" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={pageUrl} />

    <meta property="og:locale" content="uk_UA" />
    <meta property="og:site_name" content="АВКУ — Асоціація волонтерських команд України" />
    <meta property="og:title" content="Події АВКУ — календар, формати, архів" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${baseUrl}/logo.png`} />
    <meta property="og:image:alt" content="Логотип АВКУ" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Події АВКУ — календар, формати, архів" />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${baseUrl}/logo.png`} />

    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />

    <script type="application/ld+json" is:inline>
      {JSON.stringify(eventsJsonLd)}
    </script>
  </Fragment>

  <!-- HERO -->
  <section class="hero">
    <div class="container hero-content">
      <h1 class="hero-header" data-translate-en="AVKU events and activities">Події та заходи АВКУ</h1>

      <p class="hero-slogan" data-translate-en="Event formats, how to join, and a selected archive.">
        Тут — формати подій, як долучитися, і вибраний архів.
      </p>

      <p data-translate-en="We publish upcoming event announcements in the Facebook group. On the site you will find the structure, clear steps for volunteers, and examples of past events.">
        Анонси найближчих подій ми публікуємо у Facebook-групі. На сайті — структура,
        зрозумілі кроки для волонтера і приклади подій.
      </p>

      <div class="hero-actions" style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
        <a href="/donate" class="btn" aria-label="Перейти до донату" data-translate-en="Support" data-translate-en-aria-label="Go to donations">Підтримати</a>
        <a href="/join" class="btn" aria-label="Перейти до сторінки волонтера" data-translate-en="Become a volunteer" data-translate-en-aria-label="Go to the volunteer page">Стати волонтером</a>
        <a href={links.facebookGroup} class="btn" target="_blank" rel="noopener noreferrer"
           aria-label="Відкрити Facebook-групу АВКУ (нове вікно)"
           data-translate-en="Announcements on Facebook"
           data-translate-en-aria-label="Open the AVKU Facebook group in a new window">
          Анонси у Facebook
        </a>
      </div>

      <p style="margin-top:16px; font-size:0.95rem; opacity:0.9;" data-translate-en="For a quick start, write to us or come to an announced event. We will explain what to do.">
        Якщо не трудно, для швидкого включення напиши нам або прийди на подію з анонсу — підкажемо, що робити.
      </p>
    </div>
  </section>

  <!-- UPCOMING (коректно: без вигаданих дат) -->
  <section class="activities" id="calendar">
    <div class="container">
      <h2 class="section-title" data-translate-en="Upcoming events">Найближчі події</h2>

      <div class="activities-grid">
        {upcomingView.map((e) => (
          <div class="activity-card">
            <h3 data-translate-en={e.titleEn}>{e.title}</h3>
            <p style="opacity:0.9; margin-top:6px;">
              <strong data-translate-en={e.dateLabelEn}>{e.dateLabel}</strong> · <span data-translate-en={e.locationEn}>{e.location}</span>
            </p>
            <p data-translate-en={e.descEn}>{e.desc}</p>
            <div style="margin-top:16px;">
              {e.external ? (
                <a class="btn" href={e.href} target="_blank" rel="noopener noreferrer"
                   aria-label={`Відкрити: ${e.title} (нове вікно)`}
                   data-translate-en={e.ctaEn}
                   data-translate-en-aria-label={`Open: ${e.titleEn} (new window)`}>
                  {e.cta}
                </a>
              ) : (
                <a class="btn" href={e.href} aria-label={`Відкрити: ${e.title}`} data-translate-en={e.ctaEn} data-translate-en-aria-label={`Open: ${e.titleEn}`}>{e.cta}</a>
              )}
            </div>
          </div>
        ))}
      </div>

      <div class="view-more-container" style="margin-top:24px;">
        <a href="/contacts" class="btn" aria-label="Перейти до контактів" data-translate-en="Need help with registration or questions" data-translate-en-aria-label="Go to contacts">
          Потрібна допомога з реєстрацією / питаннями
        </a>
      </div>
    </div>
  </section>

  <!-- HOW TO JOIN -->
  <section class="trust-block">
    <div class="container">
      <h2 class="section-title" data-translate-en="How to join an event">Як долучитися до події</h2>

      <div class="activities-grid">
        <div class="activity-card">
          <h3 data-translate-en="1. Choose a format">1) Обери формат</h3>
          <p data-translate-en="See “Event formats” below or open an announcement in the Facebook group.">
            Подивись “Формати подій” нижче або відкрий анонс у Facebook-групі.
          </p>
        </div>

        <div class="activity-card">
          <h3 data-translate-en="2. Contact us">2) Звʼяжись із нами</h3>
          <p>
