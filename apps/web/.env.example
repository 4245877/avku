# apps/web — публічні змінні збірки (баняться у статичний HTML/JS).
# Скопіюйте у `.env` для локальної розробки. У продакшені задаються
# як GitHub Actions Variables (Settings → Secrets and variables → Actions → Variables),
# звідки їх читає .github/workflows/deploy-pages.yml.
#
# Чому це потрібно: сайт хоститься статично на GitHub Pages (avku.org),
# а API — це serverless-функції на Vercel. Тому браузер мусить звертатися
# до АБСОЛЮТНОГО URL Vercel. Якщо не задано — фронтенд використовує відносний
# /api/* (працює лише коли сайт і API на одному origin, напр. `vercel dev`).

# Endpoint форми звернень (apps/web/api/contact.js на Vercel):
PUBLIC_CONTACT_API_URL=https://<your-web-project>.vercel.app/api/contact

# Endpoint статусу банки Monobank (apps/web/api/monobank-jar-public.js):
PUBLIC_MONO_API_URL=https://<your-web-project>.vercel.app/api/monobank-jar-public

# sendId банки Monobank за замовчуванням:
PUBLIC_MONO_SEND_ID=AYnqhv5wj7
